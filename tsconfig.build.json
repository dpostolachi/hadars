{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "dist",
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": false,
    "noEmit": false,
    "allowImportingTsExtensions": false,
    "module": "ES2020",
    "target": "ES2020",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "rootDir": ".",
    "skipLibCheck": true
  },
  "include": [
    "src/**/*",
    "index.ts",
    "cli.ts"
  ],
  "exclude": [
    "node_modules",
    "test",
    "dist"
  ]
}
