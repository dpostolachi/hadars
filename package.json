{
  "name": "hadars",
  "version": "0.1.10",
  "description": "Minimal SSR framework for React — rspack, HMR, TypeScript, Bun/Node/Deno",
  "module": "./dist/index.js",
  "type": "module",
  "bin": {
    "hadars": "dist/cli.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "src",
    "cli-lib.ts",
    "cli.ts",
    "index.ts",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./cli": {
      "import": "./dist/cli.js",
      "require": "./dist/cli.js"
    }
  },
  "scripts": {
    "build:lib": "tsup src/index.tsx --format esm,cjs --dts --out-dir dist --clean --external '@rspack/*' --external '@rspack/binding'",
    "build:cli": "node build-scripts/build-cli.mjs",
    "build:all": "npm run build:lib && npm run build:cli",
    "test": "bun test test/ssr.test.ts",
    "prepare": "npm run build:all",
    "prepublishOnly": "npm run build:all"
  },
  "keywords": [
    "react",
    "ssr",
    "server-side-rendering",
    "rspack",
    "typescript",
    "bun",
    "deno",
    "hmr",
    "framework",
    "streaming"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "peerDependencies": {
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "typescript": "^5"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  },
  "optionalDependencies": {
    "@rspack/core": "1.4.9",
    "@rspack/dev-server": "^1.2.1",
    "@rspack/plugin-react-refresh": "^1.6.1",
    "@swc/core": "^1.15.18",
    "@types/bun": "latest",
    "react-refresh": "^0.17.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.0.0",
    "esbuild": "^0.19.12",
    "tsup": "^6.7.0"
  },
  "dependencies": {
    "@mdx-js/loader": "^3.1.1",
    "@svgr/webpack": "^8.1.0",
    "postcss": "^8.5.8",
    "postcss-loader": "^8.2.1"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dpostolachi/hadars.git"
  },
  "bugs": {
    "url": "https://github.com/dpostolachi/hadars/issues"
  },
  "homepage": "https://github.com/dpostolachi/hadars#readme"
}
